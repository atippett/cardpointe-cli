# CardPointe API Configuration
# Copy this file to .env and fill in your actual values

# CoPilot API (Billing Plans) - Bearer Token Authentication
CARDCONNECT_TOKEN=your_copilot_token_here

# CardPointe Gateway API (Transactions) - Credential Authentication
CARDCONNECT_USERNAME=your_gateway_username
CARDCONNECT_PASSWORD=your_gateway_password
CARDCONNECT_SITE=fts-uat
CARDCONNECT_MERCHID=your_merchant_id

# Optional: Override default API base URL
# CARDCONNECT_API_URL=https://api-uat.cardconnect.com
