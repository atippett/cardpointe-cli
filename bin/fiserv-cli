#!/usr/bin/env node

const { Command } = require('commander');
const chalk = require('chalk');
const path = require('path');
const fs = require('fs');
const yaml = require('js-yaml');
const os = require('os');

const billingPlanCommands = require('../commands/billingplan');
const profileCommands = require('../commands/profile');
const testCommands = require('../commands/test');

const program = new Command();

program
  .name('fiserv-cli')
  .description('CardPointe CLI tool for managing billing plans and payments')
  .version('1.0.0')
  .option('-p, --profile <name>', 'Configuration profile to use (global)')
  .action(() => program.help());

function getProfileNameFromOptions(commandOptions) {
  const globalProfile = program.opts().profile;
  return commandOptions?.profile || globalProfile;
}

function getFirstProfileName(profiles) {
  if (!profiles || typeof profiles !== 'object') return 'default';
  const names = Object.keys(profiles);
  return names.length > 0 ? names[0] : 'default';
}

function resolveConfigPath() {
  const homePath = path.join(os.homedir(), '.fiserv-cli');
  const legacyPath = path.join(__dirname, '../config/local.yaml');
  const legacyHome = path.join(os.homedir(), '.cardpointe-cli');
  if (fs.existsSync(homePath)) return homePath;
  if (fs.existsSync(legacyHome)) return legacyHome;
  return legacyPath;
}

function ensureConfigFilePermissions() {
  if (process.platform === 'win32') return;
  const paths = [
    path.join(os.homedir(), '.fiserv-cli'),
    path.join(os.homedir(), '.cardpointe-cli'),
    path.join(__dirname, '../config/local.yaml')
  ];
  for (const configPath of paths) {
    try {
      if (fs.existsSync(configPath)) {
        fs.chmodSync(configPath, 0o600);
      }
    } catch (err) {
      // Non-fatal; log but continue
      console.error(chalk.yellow('Warning: Could not set permissions on'), configPath, err.message);
    }
  }
}

const GLOBAL_CONFIG_PATH = path.join(__dirname, '../config/global.yaml');

function loadGlobalConfig() {
  try {
    if (fs.existsSync(GLOBAL_CONFIG_PATH)) {
      const contents = fs.readFileSync(GLOBAL_CONFIG_PATH, 'utf8');
      return yaml.load(contents) || {};
    }
  } catch (err) {
    // Non-fatal; fall back to user config only
  }
  return {};
}

function mergeConfig(globalConfig, userConfig) {
  return {
    ...globalConfig,
    ...userConfig,
    global: userConfig.global ?? globalConfig.global,
    command: userConfig.command ?? globalConfig.command,
    profiles: userConfig.profiles ?? globalConfig.profiles,
  };
}

function flattenCredentials(flat) {
  const c = flat.copilot || {};
  const g = flat.cardpointe || {};
  return {
    ...flat,
    username: c.username ?? flat.username,
    password: c.password ?? flat.password,
    client_id: c.client_id ?? flat.client_id,
    client_secret: c.client_secret ?? flat.client_secret,
    cardpointe_username: g.username ?? flat.cardpointe_username,
    cardpointe_password: g.password ?? flat.cardpointe_password
  };
}

function loadConfig() {
  const globalConfig = loadGlobalConfig();
  const configPath = resolveConfigPath();
  try {
    if (fs.existsSync(configPath)) {
      const contents = fs.readFileSync(configPath, 'utf8');
      const userConfig = yaml.load(contents) || {};
      const config = mergeConfig(globalConfig, userConfig);
      const activeName = config.profile || getFirstProfileName(config.profiles);
      const activeProfile = (config.profiles && config.profiles[activeName]) || {};
      let flattened = { ...activeProfile, ...config, global: config.global };
      delete flattened.profiles;
      delete flattened.profile;
      flattened = flattenCredentials(flattened);

      if (flattened.client_id && !process.env.CARDCONNECT_CLIENT_ID) {
        process.env.CARDCONNECT_CLIENT_ID = flattened.client_id;
      }
      if (flattened.client_secret && !process.env.CARDCONNECT_CLIENT_SECRET) {
        process.env.CARDCONNECT_CLIENT_SECRET = flattened.client_secret;
      }
      if (flattened.username && !process.env.CARDCONNECT_USERNAME) {
        process.env.CARDCONNECT_USERNAME = flattened.username;
      }
      if (flattened.password && !process.env.CARDCONNECT_PASSWORD) {
        process.env.CARDCONNECT_PASSWORD = flattened.password;
      }
      if (flattened.sitename && !process.env.CARDCONNECT_SITE) {
        process.env.CARDCONNECT_SITE = flattened.sitename;
      }
      return flattened;
    }
    // No user config; use global only
    const flattened = { ...globalConfig };
    delete flattened.profiles;
    delete flattened.profile;
    return flattened;
  } catch (err) {
    console.error(chalk.red('Error loading configuration:'), err.message);
    process.exit(1);
  }
  return globalConfig;
}

function loadConfigWithProfile(profileName) {
  const globalConfig = loadGlobalConfig();
  const configPath = resolveConfigPath();
  try {
    if (fs.existsSync(configPath)) {
      const contents = fs.readFileSync(configPath, 'utf8');
      const userConfig = yaml.load(contents) || {};
      const config = mergeConfig(globalConfig, userConfig);
      const activeProfile = config.profiles && config.profiles[profileName];
      if (!activeProfile) {
        console.error(chalk.red(`Error: Profile '${profileName}' not found`));
        console.log(chalk.yellow('Available:'), Object.keys(config.profiles || {}).join(', '));
        process.exit(1);
      }
      let flattened = { ...activeProfile, ...config, global: config.global };
      delete flattened.profiles;
      delete flattened.profile;
      flattened = flattenCredentials(flattened);

      if (flattened.client_id && !process.env.CARDCONNECT_CLIENT_ID) {
        process.env.CARDCONNECT_CLIENT_ID = flattened.client_id;
      }
      if (flattened.client_secret && !process.env.CARDCONNECT_CLIENT_SECRET) {
        process.env.CARDCONNECT_CLIENT_SECRET = flattened.client_secret;
      }
      if (flattened.username && !process.env.CARDCONNECT_USERNAME) {
        process.env.CARDCONNECT_USERNAME = flattened.username;
      }
      if (flattened.password && !process.env.CARDCONNECT_PASSWORD) {
        process.env.CARDCONNECT_PASSWORD = flattened.password;
      }
      if (flattened.sitename && !process.env.CARDCONNECT_SITE) {
        process.env.CARDCONNECT_SITE = flattened.sitename;
      }
      return flattened;
    }
  } catch (err) {
    console.error(chalk.red('Error loading configuration:'), err.message);
    process.exit(1);
  }
  return {};
}

ensureConfigFilePermissions();
const config = loadConfig();

function setupCustomHelp() {
  const API_GROUPS = {
    copilot: 'CoPilot API',
    gateway: 'CardPointe Gateway API',
    other: 'Other'
  };
  program.configureHelp({
    formatHelp: (cmd, helper) => {
      const termWidth = helper.padWidth(cmd, helper);
      const helpWidth = helper.helpWidth || 80;
      const itemIndentWidth = 2;
      const itemSeparatorWidth = 2;
      function formatItem(term, description) {
        if (description) {
          const fullText = `${term.padEnd(termWidth + itemSeparatorWidth)}${description}`;
          return helper.wrap(fullText, helpWidth - itemIndentWidth, termWidth + itemSeparatorWidth);
        }
        return term;
      }
      function formatList(textArray) {
        return textArray.join('\n').replace(/^/gm, ' '.repeat(itemIndentWidth));
      }
      let output = [`Usage: ${helper.commandUsage(cmd)}`, ''];
      const commandDescription = helper.commandDescription(cmd);
      if (commandDescription.length > 0) {
        output = output.concat([helper.wrap(commandDescription, helpWidth, 0), '']);
      }
      const argumentList = helper.visibleArguments(cmd).map((arg) =>
        formatItem(helper.argumentTerm(arg), helper.argumentDescription(arg))
      );
      if (argumentList.length > 0) {
        output = output.concat(['Arguments:', formatList(argumentList), '']);
      }
      const optionList = helper.visibleOptions(cmd).map((opt) =>
        formatItem(helper.optionTerm(opt), helper.optionDescription(opt))
      );
      if (optionList.length > 0) {
        output = output.concat(['Options:', formatList(optionList), '']);
      }
      const commands = helper.visibleCommands(cmd);
      if (commands.length > 0) {
        const byApi = { copilot: [], gateway: [], other: [] };
        for (const c of commands) {
          const api = c.api || 'other';
          byApi[api] = byApi[api] || [];
          byApi[api].push(c);
        }
        const order = ['copilot', 'gateway', 'other'];
        for (const api of order) {
          const list = byApi[api] || [];
          if (list.length > 0) {
            output = output.concat(['', `${API_GROUPS[api] || api}:`, '']);
            const items = list.map((c) =>
              formatItem(helper.subcommandTerm(c), helper.subcommandDescription(c))
            );
            output = output.concat([formatList(items)]);
          }
        }
      }
      return output.join('\n');
    }
  });
}

const billingplanCmd = program.command('billingplan').description('Manage billing plans').action(() => program.help());
billingplanCmd.api = 'copilot';
const profileCmd = program.command('profile').description('Manage payment profiles').action(() => program.help());
profileCmd.api = 'gateway';

const testCmd = program
  .command('test [testName] [merchantId]')
  .description('List or run unit tests (e.g. auth.copilot, auth.cardpointe <merchantId>)')
  .option('-p, --profile <name>', 'Configuration profile to use')
  .action(async (testName, merchantId, options) => {
    try {
      const profileName = getProfileNameFromOptions(options);
      const activeConfig = profileName ? loadConfigWithProfile(profileName) : config;
      await testCommands.runTests({ ...options, profile: profileName, args: testName ? [testName, merchantId] : [], merchantId }, activeConfig);
    } catch (err) {
      console.error(chalk.red('Error:'), err.message);
      process.exit(1);
    }
  });
testCmd.api = 'other';

const listCmd = program
  .command('billingplan.list <merchantId>')
  .description('List all billing plans for a merchant')
  .option('-p, --profile <name>', 'Configuration profile to use')
  .option('-f, --format <format>', 'Output format (pretty, table, csv)', 'pretty')
  .option('-v, --verbose', 'Enable verbose debug output')
  .option('--page-number <number>', 'Page number')
  .option('--page <number>', 'Page number')
  .option('--size <number>', 'Page size')
  .option('--limit <number>', 'Limit')
  .option('--offset <number>', 'Offset')
  .option('--skip <number>', 'Skip')
  .action(async (merchantId, options) => {
    try {
      const profileName = getProfileNameFromOptions(options);
      const activeConfig = profileName ? loadConfigWithProfile(profileName) : config;
      await billingPlanCommands.listBillingPlans(merchantId, options, activeConfig);
    } catch (err) {
      console.error(chalk.red('Error:'), err.message);
      process.exit(1);
    }
  });
listCmd.api = 'copilot';

const getCmd = program
  .command('billingplan.get <merchantId> <billingPlanId>')
  .description('Get detailed information for a specific billing plan')
  .option('-p, --profile <name>', 'Configuration profile to use')
  .option('-v, --verbose', 'Enable verbose debug output')
  .action(async (merchantId, billingPlanId, options) => {
    try {
      const profileName = getProfileNameFromOptions(options);
      const activeConfig = profileName ? loadConfigWithProfile(profileName) : config;
      await billingPlanCommands.getBillingPlan(merchantId, billingPlanId, options, activeConfig);
    } catch (err) {
      console.error(chalk.red('Error:'), err.message);
      process.exit(1);
    }
  });
getCmd.api = 'copilot';

const cancelCmd = program
  .command('billingplan.cancel <merchantId> <billingPlanId>')
  .description('Cancel a billing plan and all remaining payments')
  .option('-p, --profile <name>', 'Configuration profile to use')
  .option('-v, --verbose', 'Enable verbose debug output')
  .action(async (merchantId, billingPlanId, options) => {
    try {
      const profileName = getProfileNameFromOptions(options);
      const activeConfig = profileName ? loadConfigWithProfile(profileName) : config;
      await billingPlanCommands.cancelBillingPlan(merchantId, billingPlanId, options, activeConfig);
    } catch (err) {
      console.error(chalk.red('Error:'), err.message);
      process.exit(1);
    }
  });
cancelCmd.api = 'copilot';

const profileGetCmd = program
  .command('profile.get <profileId> <accountId> <merchantId>')
  .description('Get payment profile details from CardPointe Gateway')
  .option('-p, --profile <name>', 'Configuration profile to use')
  .option('-v, --verbose', 'Enable verbose debug output')
  .action(async (profileId, accountId, merchantId, options) => {
    try {
      const profileName = getProfileNameFromOptions(options);
      const activeConfig = profileName ? loadConfigWithProfile(profileName) : config;
      await profileCommands.getProfile(profileId, accountId, merchantId, options, activeConfig);
    } catch (err) {
      console.error(chalk.red('Error:'), err.message);
      process.exit(1);
    }
  });
profileGetCmd.api = 'gateway';

const exportCmd = program
  .command('billingplan.export [inputCsv]')
  .description('Export billing plan details from CSV (reads stdin if inputCsv omitted)')
  .option('-p, --profile <name>', 'Configuration profile to use')
  .option('-o, --output <file>', 'Output CSV file path')
  .option('--limit <number>', 'Limit export to first N rows')
  .option('--plan-id-column <name>', 'Plan ID column header')
  .option('--merchant-id-column <name>', 'Merchant ID column header')
  .option('-v, --verbose', 'Enable verbose debug output')
  .action(async (inputCsv, options) => {
    try {
      const profileName = getProfileNameFromOptions(options);
      const activeConfig = profileName ? loadConfigWithProfile(profileName) : config;
      await billingPlanCommands.exportBillingPlans(inputCsv, options, activeConfig);
    } catch (err) {
      console.error(chalk.red('Error:'), err.message);
      process.exit(1);
    }
  });
exportCmd.api = 'copilot';

setupCustomHelp();
program.parse();
